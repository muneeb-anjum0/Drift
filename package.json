{
  "name": "driftledger",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "npm run dev:go",
    "dev:go": "concurrently -n client,server-go -c cyan,green \"npm run dev --workspace client\" \"cd server-go && go run ./cmd/api\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev:server-go",
    "dev:server-go": "cd server-go && go run ./cmd/api",
    "build": "npm run build --workspace client",
    "build:client": "npm run build --workspace client",
    "build:server": "cd server-go && go test ./..."
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
