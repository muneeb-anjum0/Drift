# DriftLedger local-only Docker environment
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN_HOURS=168

# Backend -> local inference service
DRIFT_INFERENCE_ENABLED=true
DRIFT_INFERENCE_URL=http://inference:8000
DRIFT_INFERENCE_TIMEOUT_MS=65000
DRIFT_RELEVANCE_THRESHOLD=0.25
DRIFT_MAX_ANALYZED_REQUIREMENTS=3
DRIFT_EVALUATION_REPORT_DIR=/app/reports/evaluation

# Local-only model runtime
DRIFT_MODEL_MODE=local
DRIFT_LOCAL_ENGINE=gguf
DRIFT_ADAPTER_ZIP_PATH=models/adapters/DriftLedger_v5_qwen2.5_7b_LoRA.zip
DRIFT_ADAPTER_DIR=models/adapters/DriftLedger_v5_qwen2.5_7b_LoRA
DRIFT_MERGED_MODEL_DIR=models/merged/DriftLedger-Qwen2.5-7B-Merged
DRIFT_GGUF_F16_PATH=models/gguf/DriftLedger-Qwen2.5-7B-F16.gguf
DRIFT_GGUF_Q4KM_PATH=models/gguf/DriftLedger-Qwen2.5-7B-Q4_K_M.gguf
DRIFT_GGUF_MODEL_PATH=/app/models/gguf/DriftLedger-Qwen2.5-7B-Q4_K_M.gguf
VITE_DRIFT_MODEL_LABEL=Qwen2.5-7B + DriftLedger LoRA (GGUF Q4_K_M)
DRIFT_LLAMA_SERVER_URL=http://llama:8080
DRIFT_LLAMA_CTX_SIZE=768
DRIFT_LLAMA_GPU_LAYERS=0
DRIFT_LLAMA_THREADS=6
DRIFT_LLAMA_MAX_TOKENS=120
DRIFT_MAX_NEW_TOKENS=224
DRIFT_ALLOW_CPU=false

# Optional only for rebuild scripts if Hugging Face requires auth.
HF_TOKEN=

# Optional local integrations
FIREBASE_STORAGE_ENABLED=false
FIREBASE_STORAGE_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=
MAX_UPLOAD_SIZE_MB=10
